# Comments generated by ChatGPT to explain what each variable is for.

# Name of the final output.
# This becomes things like:
#   build/blink.elf
#   build/blink.hex
#   build/blink.bin
PROJECT = blink

# Path to the root of the ChibiOS source tree.
# Many later include statements depend on this.
CHIBIOS = C:/dev/ChibiOS

# Directory containing project configuration headers such as:
#   chconf.h
#   halconf.h
#   mcuconf.h
CONFDIR = ./cfg

# Directory where object files and final build products go.
BUILDDIR = ./build

# Directory for generated dependency files (.d), used by make so that
# changed headers trigger rebuilds.
DEPDIR = ./.dep


# General compiler optimization/debug options shared by C and C++.
# -O2                  optimization level
# -ggdb                include debug info
# --specs=nano.specs   use newlib-nano to reduce code size
USE_OPT = -O2 -ggdb --specs=nano.specs

# Extra C-only compiler options.
USE_COPT =

# Extra C++-only compiler options.
# -fno-rtti is common in embedded systems to reduce overhead.
USE_CPPOPT = -fno-rtti

# If yes, linker garbage-collects unused functions/data sections.
# This helps remove dead code from the final binary.
USE_LINK_GC = yes

# Enable link-time optimization.
# Can improve code size/speed, but occasionally complicates debugging.
USE_LTO = yes

# If yes, show full compile commands instead of short summaries.
USE_VERBOSE_COMPILE = no

# ChibiOS "smart build" tries to avoid compiling unused modules.
USE_SMART_BUILD = yes


# Stack size for the process/main thread.
# In ChibiOS, main() becomes a thread after chSysInit().
USE_PROCESS_STACKSIZE = 0x400

# Stack size for exceptions/interrupt handling.
USE_EXCEPTIONS_STACKSIZE = 0x400


# Target CPU core. For STM32H563ZI this should be Cortex-M33.
MCU = cortex-m33

# Floating-point ABI.
# "hard" means hardware floating-point calling convention is used.
USE_FPU = hard

# Exact compiler flags for the FPU.
# $(USE_FPU) expands to "hard" here.
USE_FPU_OPT = -mfloat-abi=$(USE_FPU) -mfpu=fpv5-sp-d16


# Pulls in license-related build metadata.
include $(CHIBIOS)/os/license/license.mk

# Startup code and linker-script helper variables for STM32H5xx.
# This is where variables like STARTUPLD usually come from.
include $(CHIBIOS)/os/common/startup/ARMCMx/compilers/GCC/mk/startup_stm32h5xx.mk

# ChibiOS object-oriented support layer sources/includes.
include $(CHIBIOS)/os/common/oop/oop.mk

# Common utility sources/includes.
include $(CHIBIOS)/os/common/utils/utils.mk

# XHAL (extended HAL) framework sources/includes.
include $(CHIBIOS)/os/xhal/xhal.mk

# STM32H5-specific platform support.
# This brings in family-specific HAL/platform files.
include $(CHIBIOS)/os/xhal/ports/STM32/STM32H5xx/platform.mk

# Board support package for the NUCLEO-H563ZI board.
# This usually contributes board.c and board include paths.
include $(CHIBIOS)/os/hal/boards/ST_NUCLEO144_H563ZI/board.mk

# OSAL layer selection.
# This bridges the HAL to the RT kernel interface.
include $(CHIBIOS)/os/hal/osal/rt-nil/osal.mk

# ChibiOS RT kernel sources/includes.
include $(CHIBIOS)/os/rt/rt.mk

# CPU port files for ARMv8-M Mainline using GCC.
# This is the ChibiOS kernel/port layer for Cortex-M33-class devices.
include $(CHIBIOS)/os/common/ports/ARMv8-M-ML-ALT/compilers/GCC/mk/port.mk


# Linker script used to place code/data in the STM32H563 memory map.
# STARTUPLD is usually set by startup_stm32h5xx.mk.
LDSCRIPT = $(STARTUPLD)/STM32H563xI.ld


# Final list of C source files to compile.
# ALLCSRC is built up by the included .mk files above.
# main.c is your application entry point.
CSRC = $(ALLCSRC) main.c

# Final list of C++ sources.
# Often empty unless you add your own .cpp files or some module provides them.
CPPSRC = $(ALLCPPSRC)

# Pure assembly source files.
ASMSRC = $(ALLASMSRC)

# Assembly files that need preprocessing first.
ASMXSRC = $(ALLXASMSRC)


# Include directories for the compiler.
# CONFDIR gives your cfg/*.h files.
# ALLINC comes from the included ChibiOS .mk fragments.
INCDIR = $(CONFDIR) $(ALLINC)


# Warning flags for C files.
CWARN = -Wall -Wextra -Wundef -Wstrict-prototypes -Wcast-align=strict

# Warning flags for C++ files.
CPPWARN = -Wall -Wextra -Wundef


# User-defined preprocessor macros added with -D...
# Here, this enables a compatibility mode for the OOP layer.
UDEFS = -DOOP_USE_LEGACY

# User-defined assembler preprocessor macros.
UADEFS =

# Extra include directories for your own project code.
UINCDIR =

# Extra library search directories.
ULIBDIR =

# Extra libraries to link against.
ULIBS =


# Path to the generic GCC rule files used by ChibiOS.
RULESPATH = $(CHIBIOS)/os/common/startup/ARMCMx/compilers/GCC/mk

# Toolchain definitions:
# names/paths for gcc, g++, ld, objcopy, size, etc.
include $(RULESPATH)/arm-none-eabi.mk

# The actual build rules and main targets live here.
# This file defines how .c/.cpp/.s become .o, and how objects become .elf/.hex/.bin.
include $(RULESPATH)/rules.mk
